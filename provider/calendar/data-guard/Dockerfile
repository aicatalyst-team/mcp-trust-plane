FROM node:20-alpine
WORKDIR /app
COPY _lib /app/provider/_lib
COPY calendar/data-guard /app/provider/calendar/data-guard
WORKDIR /app/provider/calendar/data-guard
EXPOSE 6310
ENV PORT=6310
HEALTHCHECK --interval=30s --timeout=3s CMD wget -qO- http://localhost:6310/health || exit 1
CMD ["node", "index.js"]
